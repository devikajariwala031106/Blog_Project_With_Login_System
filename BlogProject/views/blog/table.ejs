<%- include('../layouts/header', { active: 'blogs' }) %>

<div class="d-flex flex-wrap justify-content-between align-items-end mb-4 gap-2">
  <div>
    <h1 class="page-heading">All Blogs</h1>
    <p class="page-subheading mb-0">Manage every blog post from one place</p>
  </div>
  <a href="/blog/create" class="btn btn-accent"><i class="fa-solid fa-square-plus me-2"></i>New Blog</a>
</div>

<div class="glass-card p-4">
  <% if (blogs.length === 0) { %>
    <div class="empty-state">
      <i class="fa-regular fa-folder-open"></i>
      <p class="mb-3">No blogs found</p>
      <a href="/blog/create" class="btn btn-accent btn-sm">Create your first blog</a>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table-dark-glass">
        <thead>
          <tr>
            <th>#</th>
            <th>Image</th>
            <th>Title</th>
            <th>Category</th>
            <th>Author</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% blogs.forEach(function(blog, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><img src="<%= blog.imageUrl %>" class="table-thumb" alt="<%= blog.title %>"></td>
              <td><%= blog.title %></td>
              <td><span class="badge-category"><%= blog.category %></span></td>
              <td><%= blog.author %></td>
              <td><%= blog.createdAt.toDateString() %></td>
              <td>
                <div class="d-flex gap-2">
                  <a href="/blog/edit/<%= blog._id %>" class="btn-icon-sm edit" title="Edit">
                    <i class="fa-solid fa-pen"></i>
                  </a>
                  <form action="/blog/delete/<%= blog._id %>?_method=DELETE" method="POST" data-confirm-delete>
                    <button type="submit" class="btn-icon-sm delete" title="Delete">
                      <i class="fa-solid fa-trash"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../layouts/footer') %>
