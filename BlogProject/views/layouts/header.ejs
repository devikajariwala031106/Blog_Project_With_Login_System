<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | BlogSphere</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-shell">

  <nav class="navbar app-navbar">
    <div class="container-fluid d-flex justify-content-between align-items-center">
      <a class="navbar-brand" href="<%= isAuthenticated ? '/dashboard' : '/signin' %>">
        <span class="brand-mark">B</span>
        BlogSphere
      </a>

      <% if (isAuthenticated) { %>
        <div class="d-flex align-items-center gap-3">
          <span class="user-pill">
            <span class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            <%= currentUser.name %>
          </span>
          <a href="/logout" class="btn-logout">
            <i class="fa-solid fa-arrow-right-from-bracket me-1"></i>Logout
          </a>
        </div>
      <% } else { %>
        <div class="d-flex align-items-center gap-2">
          <a href="/signin" class="nav-link">Sign In</a>
          <a href="/signup" class="btn btn-accent btn-sm">Sign Up</a>
        </div>
      <% } %>
    </div>
  </nav>

  <% if (typeof layout !== 'undefined' && layout === 'auth') { %>
    <main class="auth-shell">
      <div class="w-100" style="max-width:440px;">
        <% if (typeof messages !== 'undefined' && messages.length) { %>
          <% messages.forEach(function(msg) { %>
            <div class="alert alert-glass alert-<%= msg.type %> mb-3" data-auto-dismiss role="alert"><%= msg.text %></div>
          <% }) %>
        <% } %>
  <% } else { %>
    <div class="app-body">
      <aside class="app-sidebar">
        <a href="/dashboard" class="sidebar-link <%= active === 'dashboard' ? 'active' : '' %>">
          <i class="fa-solid fa-grip-vertical"></i><span>Dashboard</span>
        </a>
        <a href="/blogs" class="sidebar-link <%= active === 'blogs' ? 'active' : '' %>">
          <i class="fa-solid fa-table-list"></i><span>Blogs</span>
        </a>
        <a href="/blog/create" class="sidebar-link <%= active === 'create' ? 'active' : '' %>">
          <i class="fa-solid fa-square-plus"></i><span>Create Blog</span>
        </a>
      </aside>
      <main class="app-main">
        <% if (typeof messages !== 'undefined' && messages.length) { %>
          <% messages.forEach(function(msg) { %>
            <div class="alert alert-glass alert-<%= msg.type %> mb-3" data-auto-dismiss role="alert"><%= msg.text %></div>
          <% }) %>
        <% } %>
  <% } %>
